[Unit]
Description=Sentinel SQLite DB backup
After=sentinel.service

[Service]
Type=oneshot
User=sentinel
Group=sentinel
ExecStart=/opt/sentinel/deploy/backup_sentinel_db.sh
# sandbox (rovnaký prístup ako hlavná služba)
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
CapabilityBoundingSet=
ReadWritePaths=/opt/sentinel/data
